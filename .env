# ============================================================
# A.L.S — Environment Configuration
# Domain: data.ailifesolution.com
# Server: 45.91.169.201 (Amsterdam, EU)
# ============================================================

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Port the server will listen on
PORT=3000

# Host address (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Node environment (production/development)
NODE_ENV=production

# Server timezone
TZ=Europe/Amsterdam

# ============================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================================

# SMTP Host
SMTP_HOST=smtp.gmail.com

# SMTP Port (465 for SSL, 587 for TLS)
SMTP_PORT=465

# Use secure SSL/TLS
SMTP_SECURE=true

# Gmail Account (your verified email)
SMTP_USER=citytechuk@gmail.com

# Gmail App Password (not your regular password!)
# Generated: 2026-07-01
SMTP_PASS=odnjyxywzrcgubzw

# From email address
SMTP_FROM=citytechuk@gmail.com

# From name shown in emails
SMTP_FROM_NAME=A.L.S Secure Storage

# ============================================================
# DOWNLOAD CONFIGURATION
# ============================================================

# Download timeout in milliseconds (30 seconds)
DOWNLOAD_TIMEOUT=30000

# Maximum file size for URL downloads (100 MB)
DOWNLOAD_MAX_SIZE=104857600

# Maximum redirects to follow
DOWNLOAD_MAX_REDIRECTS=5

# ============================================================
# SECURITY CONFIGURATION
# ============================================================

# Session timeout in hours (24 hours)
SESSION_TIMEOUT_HOURS=24

# OTP expiry in minutes (5 minutes)
OTP_EXPIRY_MINUTES=5

# Maximum file upload size (100 MB)
MAX_FILE_SIZE=104857600

# Default user storage quota (10 GB)
DEFAULT_QUOTA=10737418240

# Maximum number of backup versions per file
BACKUP_RETENTION=100

# ============================================================
# ADMIN CONFIGURATION
# ============================================================

# Admin email (first user will become admin)
ADMIN_EMAIL=citytechuk@gmail.com

# Admin username
ADMIN_USERNAME=admin

# ============================================================
# RATE LIMITING (Custom — No Rate Limit as Requested)
# ============================================================

# Disable rate limiting globally
RATE_LIMIT_ENABLED=false

# Maximum requests per window (ignored if disabled)
RATE_LIMIT_MAX=0

# Rate limit window in milliseconds (ignored if disabled)
RATE_LIMIT_WINDOW=0

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# Enable activity logging
LOG_ACTIVITY=true

# Log file path
LOG_FILE_PATH=./logs/

# Maximum log file size (10 MB)
LOG_MAX_SIZE=10485760

# Number of log files to keep
LOG_BACKUP_COUNT=5

# ============================================================
# DATABASE CONFIGURATION (JSON)
# ============================================================

# Database path (relative to project root)
DB_PATH=./database/

# System data path
SYSTEMDATA_PATH=./systemdata/

# Uploads path
UPLOADS_PATH=./database/uploads/

# ============================================================
# CORS CONFIGURATION
# ============================================================

# Allowed origins (comma-separated, * for all)
CORS_ORIGIN=*

# Allowed methods
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers
CORS_HEADERS=Content-Type,Authorization,X-Session-Token

# ============================================================
# PERFORMANCE CONFIGURATION
# ============================================================

# Maximum concurrent uploads
MAX_CONCURRENT_UPLOADS=10

# Chunk size for large uploads (5 MB)
UPLOAD_CHUNK_SIZE=5242880

# Enable compression for responses
COMPRESSION_ENABLED=true

# Static file cache duration (1 day)
STATIC_CACHE_DURATION=86400

# ============================================================
# BACKUP CONFIGURATION
# ============================================================

# Enable automatic versioning
VERSIONING_ENABLED=true

# Keep all versions (if false, only keep BACKUP_RETENTION)
KEEP_ALL_VERSIONS=false

# Backup cleanup schedule (cron: daily at 2 AM)
BACKUP_CLEANUP_SCHEDULE="0 2 * * *"

# Compress backup files (zip)
BACKUP_COMPRESSION=false

# ============================================================
# SECURITY HEADERS
# ============================================================

# Enable security headers
SECURITY_HEADERS_ENABLED=true

# Content Security Policy
CSP_HEADER="default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' https://cdnjs.cloudflare.com 'unsafe-inline'; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data:"

# ============================================================
# DOMAIN CONFIGURATION
# ============================================================

# Public domain
PUBLIC_DOMAIN=data.ailifesolution.com

# Base URL
BASE_URL=https://data.ailifesolution.com

# API base URL
API_URL=https://data.ailifesolution.com/api

# ============================================================
# SYSTEM IDENTIFICATION
# ============================================================

# System name
SYSTEM_NAME=A.L.S

# System version
SYSTEM_VERSION=1.0.0

# Deployment ID (unique per deployment)
DEPLOYMENT_ID=als_eu_ams_001

# ============================================================
# END OF CONFIGURATION
# ============================================================
