{
  "name": "als",
  "version": "1.0.0",
  "description": "A.L.S — Advanced Local Storage: Self-contained file management system with versioning, backup, and OTP authentication.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install": "./install.sh",
    "uninstall": "./uninstall.sh",
    "test": "echo \"No tests yet\" && exit 0",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf database/uploads/* systemdata/*.tmp logs/*.tmp"
  },
  "keywords": [
    "file-storage",
    "backup",
    "versioning",
    "json-database",
    "self-hosted",
    "otp-auth",
    "file-management",
    "nodejs",
    "express"
  ],
  "author": "Ailife Solution <info@ailifesolution.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ailifesolution/als"
  },
  "bugs": {
    "url": "https://github.com/ailifesolution/als/issues"
  },
  "homepage": "https://data.ailifesolution.com",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0"
  }
}
